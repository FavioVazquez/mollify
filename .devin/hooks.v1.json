{
  "PostToolUse": [
    {
      "matcher": "^(edit|write|str_replace_editor)$",
      "hooks": [
        { "type": "command", "command": "bash /home/user/mollify/scripts/mollify-report.sh", "timeout": 60 }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": "",
      "hooks": [
        { "type": "command", "command": "bash /home/user/mollify/scripts/mollify-report.sh", "timeout": 90 }
      ]
    }
  ]
}
